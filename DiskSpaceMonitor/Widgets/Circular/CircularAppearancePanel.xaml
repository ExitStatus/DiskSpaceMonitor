<UserControl x:Class="DiskSpaceMonitor.Widgets.Circular.CircularAppearancePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="6,16,6,6">

        <TextBlock Text="Background" FontSize="13" Margin="0,0,0,4"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="BackgroundSlider" Grid.Column="0"
                    Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                    VerticalAlignment="Center" ValueChanged="OnBackgroundChanged"/>
            <TextBlock x:Name="BackgroundValue" Grid.Column="1" Width="44"
                       TextAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <TextBlock Text="Ring thickness" FontSize="13" Margin="0,16,0,4"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="ThicknessSlider" Grid.Column="0"
                    Minimum="4" Maximum="40" SmallChange="1" LargeChange="4"
                    VerticalAlignment="Center" ValueChanged="OnThicknessChanged"/>
            <TextBlock x:Name="ThicknessValue" Grid.Column="1" Width="44"
                       TextAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <TextBlock Text="Ring turns 'low' when free space drops below" FontSize="13" Margin="0,20,0,4"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="LowThresholdSlider" Grid.Column="0"
                    Minimum="1" Maximum="90" SmallChange="1" LargeChange="5"
                    VerticalAlignment="Center" ValueChanged="OnLowThresholdChanged"/>
            <TextBlock x:Name="LowThresholdValue" Grid.Column="1" Width="44"
                       TextAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <TextBlock Text="Ring turns 'critical' when free space drops below" FontSize="13" Margin="0,16,0,4"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="CriticalThresholdSlider" Grid.Column="0"
                    Minimum="1" Maximum="90" SmallChange="1" LargeChange="5"
                    VerticalAlignment="Center" ValueChanged="OnCriticalThresholdChanged"/>
            <TextBlock x:Name="CriticalThresholdValue" Grid.Column="1" Width="44"
                       TextAlignment="Right" VerticalAlignment="Center"/>
        </Grid>
    </StackPanel>
</UserControl>
