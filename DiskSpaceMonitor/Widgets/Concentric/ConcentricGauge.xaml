<UserControl x:Class="DiskSpaceMonitor.Widgets.Concentric.ConcentricGauge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- The Canvas is sized per render to the total ring diameter; the Uniform Viewbox
         then scales the whole thing to fit the (square) window for any drive count. -->
    <Viewbox Stretch="Uniform">
        <Canvas x:Name="Surface" Width="200" Height="200"/>
    </Viewbox>
</UserControl>
