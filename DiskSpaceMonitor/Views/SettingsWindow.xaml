<views:ThemedWindow x:Class="DiskSpaceMonitor.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DiskSpaceMonitor.Views"
        Title="Disk Space Monitor — Settings"
        Width="540" Height="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Topmost="True">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top-level tabs: General, then the selected widget's own tabs (added in code). -->
        <TabControl x:Name="Tabs" Grid.Row="0">
            <TabItem Header="General">
                <StackPanel Margin="10">

                    <CheckBox x:Name="AutoStartCheck" FontSize="13"
                              Margin="0,0,0,14" Content="Auto-start when I log in"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Update every" FontSize="13" VerticalAlignment="Center"/>
                        <ComboBox x:Name="IntervalCombo" Grid.Column="1" HorizontalAlignment="Left" MinWidth="130"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Widget" FontSize="13" VerticalAlignment="Center"/>
                        <ComboBox x:Name="WidgetSelector" Grid.Column="1" HorizontalAlignment="Left"
                                  MinWidth="180" SelectionChanged="OnWidgetSelected"/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Overall opacity" FontSize="13" VerticalAlignment="Center"/>
                        <Slider x:Name="OpacitySlider" Grid.Column="1"
                                Minimum="0.2" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                                VerticalAlignment="Center" ValueChanged="OnOpacityChanged"/>
                        <TextBlock x:Name="OpacityValue" Grid.Column="2" Width="44"
                                   TextAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </TabItem>

            <TabItem Header="Drives">
                <DockPanel Margin="10">
                    <TextBlock DockPanel.Dock="Bottom" Text="At least one drive must be shown."
                               Opacity="0.6" FontSize="11" Margin="0,8,0,0"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="DriveList"/>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
        </TabControl>

        <!-- Buttons, always below the tabs. -->
        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Button Content="Exit Application" HorizontalAlignment="Left"
                    Padding="12,5" Click="OnExitApplication"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" MinWidth="72" Padding="12,5" Margin="0,0,8,0"
                        IsCancel="True" Click="OnCancel"/>
                <Button x:Name="OkButton" Content="OK" MinWidth="72" Padding="12,5"
                        IsDefault="True" Click="OnOk"/>
            </StackPanel>
        </Grid>
    </Grid>
</views:ThemedWindow>
