<Window x:Class="DiskSpaceMonitor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prim="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:local="clr-namespace:DiskSpaceMonitor.Views"
        Title="Disk Space Monitor"
        Width="200" Height="200"
        MinWidth="120" MinHeight="120"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="False"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        MouseLeftButtonDown="OnWindowMouseLeftButtonDown"
        MouseMove="OnWindowMouseMove"
        MouseLeftButtonUp="OnWindowMouseLeftButtonUp"
        LostMouseCapture="OnWindowLostMouseCapture"
        ContextMenuOpening="OnContextMenuOpening"
        ContextMenuClosing="OnContextMenuClosing">

    <Window.Resources>
        <!-- Small circular drag handle used for the four resize corners. -->
        <Style x:Key="ResizeHandle" TargetType="prim:Thumb">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="prim:Thumb">
                        <Ellipse Fill="#FFFFFFFF" Stroke="#FF3A78C2" StrokeThickness="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Round icon buttons (close / settings) shown in the edit overlay. -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Settings…" Click="OnSettingsClick"/>
            <MenuItem Header="Hide this drive" Click="OnExitClick"/>
            <Separator/>
            <MenuItem Header="Exit application" Click="OnExitApplicationClick"/>
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Background="Transparent">
        <!-- The current widget's view fills the window and scales with it. -->
        <ContentControl x:Name="WidgetHost"/>

        <!-- Editing overlay: shown only while Ctrl is held and the mouse is over
             the widget. Handles resize + close. The Transparent background makes
             the entire square a hit-testable surface. -->
        <Grid x:Name="EditOverlay" Visibility="Collapsed" Background="Transparent">

            <prim:Thumb Style="{StaticResource ResizeHandle}" Tag="TopLeft"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="3" Cursor="SizeNWSE"
                        DragStarted="OnResizeStarted" DragDelta="OnResizeDelta" DragCompleted="OnResizeCompleted"/>
            <prim:Thumb Style="{StaticResource ResizeHandle}" Tag="TopRight"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="3" Cursor="SizeNESW"
                        DragStarted="OnResizeStarted" DragDelta="OnResizeDelta" DragCompleted="OnResizeCompleted"/>
            <prim:Thumb Style="{StaticResource ResizeHandle}" Tag="BottomLeft"
                        HorizontalAlignment="Left" VerticalAlignment="Bottom"
                        Margin="3" Cursor="SizeNESW"
                        DragStarted="OnResizeStarted" DragDelta="OnResizeDelta" DragCompleted="OnResizeCompleted"/>
            <prim:Thumb Style="{StaticResource ResizeHandle}" Tag="BottomRight"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="3" Cursor="SizeNWSE"
                        DragStarted="OnResizeStarted" DragDelta="OnResizeDelta" DragCompleted="OnResizeCompleted"/>

            <!-- Settings button, bottom-centre. -->
            <Button Style="{StaticResource IconButton}" Content="⚙" Click="OnSettingsClick"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="0,0,0,4" FontSize="13" Background="#CC3949AB" ToolTip="Settings"/>
        </Grid>
    </Grid>
</Window>
